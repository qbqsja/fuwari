---
import WidgetLayout from "./WidgetLayout.astro";

// 填入你自己的信息进行测试
const friends = [
  { 
    name: "明月清风", 
    url: "blog.myqfeng.top", // 指向自己
    description: "明月清风の博客",
    avatar: "https://blog.myqfeng.top/about/" // 先留空，下面会处理
  },
  
];
---

<WidgetLayout name="我的朋友" icon="material-symbols:stars-outline">
    <div class="flex flex-col gap-1">
        {friends.map((friend) => (
            <a href={friend.url} target="_blank" rel="noopener noreferrer" 
               class="flex items-center gap-3 transition-all rounded-xl p-2 hover:bg-[var(--btn-plain-bg-hover)] group">
                {/* 头像：如果有图显示图，没图显示首字母 */}
                <div class="w-10 h-10 rounded-lg bg-[var(--btn-plain-bg)] flex-shrink-0 flex items-center justify-center overflow-hidden border border-black/5 dark:border-white/5">
                    {friend.avatar ? (
                        <img src={friend.avatar} alt={friend.name} class="w-full h-full object-cover" />
                    ) : (
                        <span class="text-sm font-bold opacity-40">{friend.name[0]}</span>
                    )}
                </div>
                
                {/* 文字部分 */}
                <div class="flex flex-col truncate">
                    <div class="font-bold text-sm text-[var(--text-main)] group-hover:text-[var(--primary)] transition-colors">
                        {friend.name}
                    </div>
                    <div class="text-[10px] text-[var(--text-60)] truncate">
                        {friend.description}
                    </div>
                </div>
            </a>
        ))}
    </div>
</WidgetLayout>
