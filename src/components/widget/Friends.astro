---
import WidgetLayout from "./WidgetLayout.astro";

// 填入你自己的信息进行测试
const friends = [
  { 
    name: "明月清风", 
    url: "https://blog.myqfeng.top",
    description: "明月清风の博客",
    avatar: "https://blog.myqfeng.top/assets/images/avatar.png"
  },
  { 
    name: "凉城听暖", 
    url: "https://blog.lctn.top",
    description: "凉城听暖の博客",
    avatar: "https://blog.lctn.top/assets/images/avatar.jpg"
  },
];
---

<WidgetLayout name="我的朋友" icon="material-symbols:stars-outline">
    <div class="flex flex-col gap-1">
        {friends.map((friend) => (
            <a href={friend.url} target="_blank" rel="noopener noreferrer" 
               class="flex items-center gap-3 transition-all rounded-xl p-2 
                      hover:bg-[var(--btn-plain-bg-hover)] dark:hover:bg-white/5 group">
                
                {/* 头像容器 */}
                <div class="w-10 h-10 rounded-lg bg-[var(--btn-plain-bg)] dark:bg-zinc-800 
                            flex-shrink-0 flex items-center justify-center overflow-hidden 
                            border border-black/5 dark:border-white/10">
                    {friend.avatar ? (
                        <img src={friend.avatar} alt={friend.name} class="w-full h-full object-cover" />
                    ) : (
                        <span class="text-sm font-bold opacity-40 dark:text-white">{friend.name[0]}</span>
                    )}
                </div>
                
                {/* 文字部分 */}
                <div class="flex flex-col truncate">
                    <div class="font-bold text-sm text-[var(--text-main)] dark:text-zinc-100 
                                group-hover:text-[var(--primary)] transition-colors">
                        {friend.name}
                    </div>
                    <div class="text-[10px] text-[var(--text-60)] dark:text-zinc-400 truncate">
                        {friend.description}
                    </div>
                </div>
            </a>
        ))}
    </div>
</WidgetLayout>
